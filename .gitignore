# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Ignore private_assets contents
/private_assets/*

# BUT do not ignore the .gitkeep file!
!/private_assets/.gitkeep

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/generated/prisma

/src/generated/prisma

/prisma/generated/prisma
